{
  "name": "azure-panel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host",
    "build": "vite build",
    "build:worker": "vite build --config vite.worker.config.ts",
    "build:all": "npm run build && npm run build:worker",
    "preview": "vite preview",
    "start": "node build",
    "start:worker": "node build/worker.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@azure/arm-compute": "^22.4.0",
    "@azure/arm-network": "^33.5.0",
    "@azure/arm-resources": "^5.2.0",
    "@azure/identity": "^4.9.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.4",
    "jose": "^5.10.0",
    "mysql2": "^3.14.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.20.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.30.5",
    "postcss": "^8.5.3",
    "svelte": "^5.23.2",
    "svelte-check": "^4.1.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  }
}
