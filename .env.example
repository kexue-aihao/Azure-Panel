# === 认证与加密（生产环境必须修改）===
SECRET_KEY=replace-with-long-random-string
ENCRYPTION_KEY=replace-with-32-char-secret-key-here!!

# === 补机 Worker ===
WORKER_INTERVAL_SECONDS=30
# aaPanel 生产环境设为 false，由独立 Worker 项目运行 build/worker.js，避免 Web 内嵌 Worker 双占用。
ENABLE_EMBEDDED_WORKER=false

# === Go 高性能面板主进程 ===
# Go 进程默认接管 Web/API 入口；Node 仅作为迁移期本地兼容后端。
GO_PANEL_ENABLED=true
GO_PANEL_URL=http://127.0.0.1:3000
GO_PANEL_HOST=127.0.0.1
GO_PANEL_PORT=3000
GO_PANEL_MODE=go
GO_PANEL_NODE_COMPAT_ENABLED=true
GO_PANEL_NODE_COMPAT_PORT=3001
GO_PANEL_NODE_COMPAT_URL=http://127.0.0.1:3001
GO_PANEL_TIMEOUT_MS=1500
GO_PANEL_SUBMIT_DEADLINE_SECONDS=30
GO_PANEL_QUEUE_LIMIT=128

# === 运行时内存限制（可选）===
# 低内存服务器建议 128-256；install.sh/update.sh 默认会给生产进程设置 192。
# NODE_MAX_OLD_SPACE_SIZE=192

# === 内置代理核心（可选）===
# 留空时 install.sh/update.sh 会尝试安装到 ./bin；也可手动指定已有核心路径。
# SING_BOX_BIN=/www/wwwroot/azure-panel/bin/sing-box
# XRAY_BIN=/www/wwwroot/azure-panel/bin/xray
# MANAGED_PROXY_DIR=./data/managed-proxies

# === Web 服务监听（aaPanel Nginx 反代到此处）===
HOST=127.0.0.1
PORT=3000

# === 数据库：开发默认 SQLite，aaPanel 生产推荐 MySQL ===
# DB_DRIVER=sqlite
# SQLITE_PATH=./data/azure-panel.db

DB_DRIVER=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=azure_panel
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=azure_panel
